{
  "manifest_version": 3,
  "name": "元素定位器",
  "version": "1.2.0",
  "description": "点击页面元素，自动提取定位信息，快速与 AI 协作",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": [
        "utils/extractor.js",
        "utils/framework-detector.js",
        "utils/formatter.js",
        "content.js"
      ],
      "css": ["styles.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
